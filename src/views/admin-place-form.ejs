<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= mode === 'create' ? '新增地点' : '编辑地点' %> - 管理员后台</title>
  <link rel="stylesheet" href="/styles.css" />
  <link rel="stylesheet" href="/leaflet.css" crossorigin="" />
  <style>
    /* 将编辑界面强制修改为极简黑色表单，去除所有动画与重叠 */
    body {
      background: #000 !important;
      margin: 0; padding: 20px; color: #fff; font-family: sans-serif;
    }
    body::before, body::after, #particles-canvas, .background-glow {
      display: none !important;
    }
    .wrapper {
      max-width: 800px; margin: 0 auto; background: #111; padding: 30px; border-radius: 10px;
    }
    .wrapper h1 { margin-top: 0; }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; font-weight: bold; color: #ccc; }
    .form-group input[type="text"], .form-group textarea {
      width: 100%; padding: 10px; background: #222; border: 1px solid #444; color: #fff; border-radius: 6px; box-sizing: border-box;
    }
    .hint { font-size: 12px; color: #888; margin-top: 5px; margin-bottom: 0; }
    
    .preview-box {
      border: 1px solid #444; background: #1a1a1a; padding: 15px; border-radius: 6px; margin-top: 10px;
    }
    .preview-box iframe { width: 100%; height: 350px; border: none; background: #000; display: block; }
    .preview-box img { max-width: 100%; max-height: 400px; display: block; border-radius: 4px; object-fit: contain; }
    .drawings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 10px; }
    .drawings-grid img { width: 100%; height: 120px; object-fit: cover; }
    
    button[type="submit"] {
      background: #007bff; color: #fff; padding: 12px 20px; border: none; border-radius: 6px; font-size: 16px; cursor: pointer; width: 100%; margin-top: 20px;
    }
    button[type="submit"]:hover { background: #0056b3; }
    .back-link { display: block; text-align: center; margin-top: 15px; color: #888; text-decoration: none; }
    .back-link:hover { color: #fff; }
    .btn-danger { background: #dc3545; color: #fff; padding: 6px 12px; border: none; border-radius: 4px; cursor: pointer; font-size: 12px; margin-top: 10px; }
  </style>
</head>
<body>
  <div class="wrapper">
    <h1><%= mode === 'create' ? '新增地点' : '编辑地点' %></h1>
    <% if (error) { %><p style="color: #dc3545;"><%= error %></p><% } %>
    <div id="adminNotice" style="display:none; padding:10px; margin-bottom:15px; border-radius:4px;"></div>

    <form method="post" action="<%= mode === 'create' ? '/admin/place/new' : '/admin/place/' + place.id + '/edit' %>" enctype="multipart/form-data">
      <% if (mode === 'create') { %>
      <div class="form-group">
        <label>地点 ID（字母/数字）</label>
        <input type="text" name="id" value="<%= place.id %>" required />
      </div>
      <% } %>

      <div class="form-group">
        <label>名称</label>
        <input type="text" name="name" value="<%= place.name %>" required />
      </div>

      <div class="form-group">
        <label>地图选点 (X / Y)</label>
        <div id="pickerMap" style="width:100%; height:300px; border-radius:6px; margin-bottom:10px; z-index:1;"></div>
        <div style="display:flex; gap:10px;">
          <input type="text" name="px" id="pxInput" value="<%= place.px || place.px === 0 ? place.px : '' %>" placeholder="X" required readonly style="flex:1;" />
          <input type="text" name="py" id="pyInput" value="<%= place.py || place.py === 0 ? place.py : '' %>" placeholder="Y" required readonly style="flex:1;" />
        </div>
      </div>

      <div class="form-group">
        <label>历史时期</label>
        <input type="text" name="period" value="<%= place.period %>" required />
      </div>

      <div class="form-group">
        <label>摘要</label>
        <textarea name="summary" rows="2" required><%= place.summary %></textarea>
      </div>

      <div class="form-group">
        <label>详细介绍</label>
        <textarea name="content" rows="6" required><%= place.content %></textarea>
      </div>

      <div class="form-group">
        <label>主图上传</label>
        <input type="file" name="imageFile" id="imageFileInput" accept="image/*" style="color:#fff;" />
        <p class="hint">编辑时不选择则保留原图</p>
        <input type="hidden" name="image" id="imageInput" value="<%= place.image %>" />
        <div class="preview-box">
          <p class="hint" id="mainImageHint" style="margin-top:0;">主图预览区域</p>
          <img id="mainImagePreview" src="" alt="主图预览" style="display:none;" />
          <button type="button" id="deleteMainImageBtn" class="btn-danger" style="display:none;">删除主图</button>
        </div>
      </div>

      <div class="form-group">
        <label>B站视频链接 (BV/AV号)</label>
        <input type="text" name="videoUrl" value="<%= place.videoUrl || '' %>" placeholder="例如: BV1xxxx..." />
        <div class="preview-box">
          <p class="hint" id="videoPreviewHint" style="margin-top:0;">视频预览区域</p>
          <div id="videoPreview" style="display:none;">
            <iframe id="videoPreviewFrame" src="" allowfullscreen></iframe>
          </div>
        </div>
      </div>

      <div class="form-group">
        <label>手绘图上传 (可多选)</label>
        <input type="file" name="drawingFiles" id="drawingFilesInput" accept="image/*" multiple style="color:#fff;" />
        <input type="hidden" name="drawingsText" id="drawingsTextInput" value="<%= place.drawingsText || '' %>" />
        <div class="preview-box">
          <p class="hint" id="drawingsEmptyHint" style="margin-top:0;">手绘图预览区域</p>
          <div id="drawingsPreviewGrid" class="drawings-grid"></div>
        </div>
      </div>

      <div class="form-group">
        <label>手绘图说明 (可选，按段落对应如需要)</label>
        <textarea name="drawingsCaptions" id="drawingsCaptionsInput" rows="3" placeholder="按行说明..."><%= place.drawingsCaptions || '' %></textarea>
      </div>

      <div class="form-group">
        <label>小助手预设问答</label>
        <textarea name="qaRulesText" rows="5" placeholder="问 | 答"><%= place.qaRulesText || '' %></textarea>
      </div>

      <button type="submit"><%= mode === 'create' ? '保存地点' : '保存修改' %></button>
      <a href="/admin" class="back-link">放弃并返回后台</a>
    </form>
  </div>

  <script src="/leaflet.js" crossorigin=""></script>
  <script>
    (function() {
      var pickerEl = document.getElementById("pickerMap");
      var pxInput = document.getElementById("pxInput");
      var pyInput = document.getElementById("pyInput");
      if (!pickerEl || !pxInput || !pyInput) return;

      var imgW = 2988, imgH = 4096;
      var pickerMap = L.map(pickerEl, {
        crs: L.CRS.Simple,
        zoomControl: false,
        attributionControl: false,
        minZoom: -3,
        maxZoom: 1,
        maxBounds: [[0, 0], [imgH, imgW]],
        maxBoundsViscosity: 1.0,
      });

      L.imageOverlay("/images/map_pic.jpg", [[0, 0], [imgH, imgW]]).addTo(pickerMap);
      pickerMap.fitBounds([[0, 0], [imgH, imgW]]);

      var marker = null;
      // 编辑时恢复已有标记
      var initPx = parseInt(pxInput.value) || -1;
      var initPy = parseInt(pyInput.value) || -1;
      if (initPx >= 0 && initPy >= 0) {
        marker = L.marker([initPy, initPx]).addTo(pickerMap);
        pickerMap.setView([initPy, initPx], 0);
      }

      pickerMap.on("click", function(e) {
        var py = Math.round(e.latlng.lat);
        var px = Math.round(e.latlng.lng);
        if (px < 0 || px > imgW || py < 0 || py > imgH) return;
        pxInput.value = px;
        pyInput.value = py;
        if (marker) pickerMap.removeLayer(marker);
        marker = L.marker([py, px]).addTo(pickerMap);
      });
    })();
  </script>

  <script>
    (function () {
      const currentPlaceId = "<%= place.id || '' %>";
      const imageInput = document.getElementById("imageInput");
      const mainImagePreview = document.getElementById("mainImagePreview");
      const mainImageHint = document.getElementById("mainImageHint");
  const imageFileInput = document.getElementById("imageFileInput");
  const drawingFilesInput = document.getElementById("drawingFilesInput");
  const drawingsTextInput = document.getElementById("drawingsTextInput");
  const drawingsPreviewGrid = document.getElementById("drawingsPreviewGrid");
      const drawingsEmptyHint = document.getElementById("drawingsEmptyHint");
  const deleteMainImageBtn = document.getElementById('deleteMainImageBtn');
  const videoInput = document.querySelector("input[name='videoUrl']");
  const videoPreview = document.getElementById("videoPreview");
  const videoPreviewFrame = document.getElementById("videoPreviewFrame");
  const videoPreviewHint = document.getElementById("videoPreviewHint");
  const MAX_UPLOAD_MB = 20;
  const MAX_UPLOAD_BYTES = MAX_UPLOAD_MB * 1024 * 1024;

      function normalizeLine(line) {
        const parts = line.split("|");
        const url = (parts[0] || "").trim();
        const caption = (parts[1] || "").trim();
        return { url, caption };
      }

      function setMainPreview(overrideUrl) {
        const url = (overrideUrl || imageInput.value || "").trim();
        if (!url) {
          mainImagePreview.style.display = "none";
          mainImagePreview.removeAttribute("src");
          mainImageHint.textContent = "请输入主图 URL 以查看预览";
          mainImageHint.style.display = "block";
          deleteMainImageBtn.style.display = 'none';
          return;
        }

        mainImagePreview.style.display = "block";
        mainImagePreview.src = url;
        mainImageHint.style.display = "none";
        // show delete button for any existing image
        deleteMainImageBtn.style.display = 'inline-block';
      }

      function renderDrawingsPreview() {
        const uploadedFiles = drawingFilesInput?.files ? Array.from(drawingFilesInput.files) : [];
        const lines = (drawingsTextInput.value || "")
          .split("\n")
          .map((line) => line.trim())
          .filter(Boolean);

        const items = lines
          .map(normalizeLine)
          .filter((item) => item.url);

        const uploadedItems = uploadedFiles.map((file, index) => ({
          url: URL.createObjectURL(file),
          caption: file.name || `上传图 ${index + 1}`,
          isUpload: true,
        }));

        drawingsPreviewGrid.innerHTML = "";

        if (items.length === 0 && uploadedItems.length === 0) {
          drawingsEmptyHint.style.display = "block";
          return;
        }

        drawingsEmptyHint.style.display = "none";

        [...uploadedItems, ...items].forEach((item, index) => {
          const card = document.createElement("div");
          card.style.background = "#222";
          card.style.padding = "5px";
          card.style.borderRadius = "4px";

          const img = document.createElement("img");
          img.src = item.url;
          img.alt = item.caption || `手绘图预览 ${index + 1}`;

          const caption = document.createElement("p");
          caption.style.fontSize = "12px";
          caption.style.color = "#ccc";
          caption.style.margin = "5px 0";
          caption.textContent = item.caption || `第 ${index + 1} 张`;

          card.appendChild(img);
          card.appendChild(caption);

          // If this item is an existing drawing (not newly uploaded preview), render a delete button
          if (!item.isUpload && item.url) {
            const del = document.createElement('button');
            del.type = 'button';
            del.textContent = '删除';
            del.className = 'btn-danger';
            del.style.width = '100%';
            del.addEventListener('click', async () => {
              if (!confirm('确认删除该手绘图？此操作会从服务器删除文件且不可恢复。')) return;
              try {
                const res = await fetch(`/admin/place/${encodeURIComponent(currentPlaceId)}/image/delete`, {
                  method: 'POST',
                  headers: {'Content-Type': 'application/json'},
                  body: JSON.stringify({ type: 'drawing', url: item.url })
                });
                const data = await res.json();
                if (data && data.success) {
                  // remove this card from DOM and update hidden drawingsText
                  card.remove();
                  // rebuild drawingsText from returned place.drawings
                  const newText = (data.place && Array.isArray(data.place.drawings)) ? data.place.drawings.map(d => `${d.url} | ${d.caption || ''}`).join('\n') : '';
                  drawingsTextInput.value = newText;
                  renderDrawingsPreview();
                  showNotice('手绘图已删除', 'success');
                } else {
                  showNotice((data && data.error) || '删除失败', 'error');
                }
              } catch (err) {
                console.error(err);
                showNotice('删除请求出错', 'error');
              }
            });
            card.appendChild(del);
          }

          drawingsPreviewGrid.appendChild(card);
        });
      }

      function buildBilibiliEmbed(rawUrl) {
        const url = (rawUrl || "").trim();
        if (!url) {
          return "";
        }
        if (url.includes("player.bilibili.com")) {
          return url;
        }
        const bvidMatch = url.match(/BV[0-9A-Za-z]+/);
        if (bvidMatch) {
          return `https://player.bilibili.com/player.html?bvid=${bvidMatch[0]}&high_quality=1&autoplay=0`;
        }
        const aidMatch = url.match(/av(\d+)/i);
        if (aidMatch) {
          return `https://player.bilibili.com/player.html?aid=${aidMatch[1]}&high_quality=1&autoplay=0`;
        }
        return "";
      }

      function setVideoPreview() {
        const embedUrl = buildBilibiliEmbed(videoInput?.value || "");
        if (!embedUrl) {
          videoPreview.style.display = "none";
          videoPreviewFrame.removeAttribute("src");
          videoPreviewHint.textContent = "请输入 B 站视频链接以查看预览";
          videoPreviewHint.style.display = "block";
          return;
        }
        videoPreview.style.display = "block";
        videoPreviewFrame.src = embedUrl;
        videoPreviewHint.style.display = "none";
      }

      mainImagePreview.addEventListener("error", () => {
        mainImagePreview.style.display = "none";
        mainImageHint.textContent = "主图加载失败，请检查 URL 是否正确";
        mainImageHint.style.display = "block";
      });

      imageInput.addEventListener("input", () => setMainPreview());
      if (imageFileInput) {
        imageFileInput.addEventListener("change", () => {
          const file = imageFileInput.files && imageFileInput.files[0];
          if (file && file.size > MAX_UPLOAD_BYTES) {
            imageFileInput.value = '';
            showNotice(`主图超过 ${MAX_UPLOAD_MB}MB，请压缩后再上传。`, 'error');
            setMainPreview();
            return;
          }
          if (file) {
            const previewUrl = URL.createObjectURL(file);
            setMainPreview(previewUrl);
            return;
          }
          setMainPreview();
        });
      }
      // delete main image handler
      if (deleteMainImageBtn) {
        deleteMainImageBtn.addEventListener('click', async () => {
          if (!confirm('确认删除主图？此操作会从服务器删除文件且不可恢复。')) return;
          const url = (imageInput.value || '').trim();
          try {
            const res = await fetch(`/admin/place/${encodeURIComponent(currentPlaceId)}/image/delete`, {
              method: 'POST',
              headers: {'Content-Type': 'application/json'},
              body: JSON.stringify({ type: 'main', url })
            });
            const data = await res.json();
            if (data && data.success) {
              // clear hidden input and preview
              imageInput.value = '';
              setMainPreview();
              showNotice('主图已删除，您可以重新上传', 'success');
            } else {
              showNotice((data && data.error) || '删除失败', 'error');
            }
          } catch (err) {
            console.error(err);
            showNotice('删除请求出错', 'error');
          }
        });
      }

      function showNotice(message, type) {
        const el = document.getElementById('adminNotice');
        if (!el) return;
        el.textContent = message || '';
        el.style.display = message ? 'block' : 'none';
        el.style.background = type === 'success' ? 'rgba(20, 120, 80, 0.12)' : 'rgba(180, 40, 40, 0.12)';
        el.style.border = type === 'success' ? '1px solid rgba(20, 120, 80, 0.35)' : '1px solid rgba(180, 40, 40, 0.35)';
        el.style.color = type === 'success' ? '#0f6a4a' : '#9d1c1c';
        el.style.padding = '8px 10px';
        el.style.borderRadius = '8px';
      }
      if (drawingFilesInput) {
        drawingFilesInput.addEventListener("change", () => {
          const files = drawingFilesInput.files ? Array.from(drawingFilesInput.files) : [];
          const tooLarge = files.find((file) => file.size > MAX_UPLOAD_BYTES);
          if (tooLarge) {
            drawingFilesInput.value = '';
            showNotice(`手绘图单张超过 ${MAX_UPLOAD_MB}MB，请压缩后再上传。`, 'error');
            renderDrawingsPreview();
            return;
          }
          renderDrawingsPreview();
        });
      }
      drawingsTextInput.addEventListener("input", renderDrawingsPreview);
      if (videoInput) {
        videoInput.addEventListener("input", setVideoPreview);
      }

  setMainPreview();
  renderDrawingsPreview();
      setVideoPreview();
    })();
  </script>

  <footer class="site-footer">
    <p>&copy; 2026 东北大学校史地图 &middot; <a href="/admin">返回管理后台</a></p>
    <p>联系QQ：228343975</p>
  </footer>
</body>
</html>