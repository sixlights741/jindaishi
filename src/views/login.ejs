<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>登录 - 东北大学校史地图</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="auth-body">
  <div class="background-glow" style="top:10%;left:10%"></div>
  <div class="background-glow" style="top:60%;left:70%;background:radial-gradient(circle,rgba(157,78,221,0.22),transparent 60%);animation-delay:2s"></div>
  <main class="auth-card">
    <img src="/images/neusign.jpg" alt="东北大学校徽" class="login-emblem" />
    <h1>东北大学校史地图</h1>

    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>

    <form method="post" action="/login" class="form">
      <input type="text" name="studentId" placeholder="学号：如20250001" required />

      <input type="password" name="password" placeholder="密码：初始密码为学号" required />

      <button type="submit">进入地图</button>
    </form>
  </main>
</body>
</html>