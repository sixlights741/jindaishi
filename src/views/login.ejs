<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>登录 - 东北大学校史地图</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="auth-body">
  <div class="background-glow"></div>
  <main class="auth-card">
    <img src="/images/neusign.jpg" alt="东北大学校徽" class="login-emblem" />
    <h1>东北大学校史地图</h1>
    <p class="subtitle">请输入学号与密码登录</p>

    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>

    <form method="post" action="/login" class="form">
      <label>学号</label>
      <input type="text" name="studentId" placeholder="如：20230001" required />

      <label>密码</label>
      <input type="password" name="password" placeholder="初始密码为学号" required />

      <button type="submit">进入地图</button>
    </form>
  </main>
</body>
</html>
