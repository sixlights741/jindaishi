<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>东北大学校史地图</title>
  <link rel="stylesheet" href="https://cdn.bootcdn.net/ajax/libs/leaflet/1.9.4/leaflet.css" crossorigin="" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <canvas id="particles-canvas"></canvas>
  <header class="topbar topbar-main">
    <div class="brand-block">
      <img src="/images/neusign.jpg" alt="东北大学校徽" class="brand-emblem" />
      <div>
      <h1>NEU数字地图</h1>
      <p>欢迎你，<%= user.studentId %></p>
      </div>
    </div>
    <div class="actions">
      <% if (user.isAdmin) { %>
        <a href="/admin" class="btn">管理员后台</a>
      <% } %>
  <a href="/profile/password" class="btn ghost">改密码</a>
      <form method="post" action="/logout">
        <button type="submit" class="btn">退出登录</button>
      </form>
    </div>
  </header>

  <section class="hero-stats">
    <div class="stat-item">
      <span class="stat-number"><%= places.length %></span>
      <span class="stat-label">历史地点</span>
    </div>
    <div class="stat-item">
      <span class="stat-number">南湖校区</span>
      <span class="stat-label">东北大学</span>
    </div>
  </section>

  <main class="container">
    <section class="panel">
      <h2>地图导航</h2>
      <p>点击地图上的发光点，进入地点详情页。</p>
      <div id="map"></div>
    </section>

    <aside class="panel list-panel">
      <h2>地点列表</h2>
      <ul class="place-list">
        <% places.forEach((place, idx) => { %>
          <li class="stagger-item stagger-<%= (idx % 8) + 1 %>">
            <a href="/place/<%= place.id %>">
              <strong><%= place.name %></strong>
              <span><%= place.summary %></span>
            </a>
          </li>
        <% }) %>
      </ul>
    </aside>
  </main>

  <script id="places-data" type="application/json"><%- JSON.stringify(places) %></script>
  <script src="https://cdn.bootcdn.net/ajax/libs/leaflet/1.9.4/leaflet.js" crossorigin=""></script>
  <script>
    const placesDataEl = document.getElementById("places-data");
    const places = JSON.parse(placesDataEl?.textContent || "[]");

    // 东北大学南湖校区范围（收紧到校园边界）
    const nanhuCenter = [41.76549250249159, 123.41870396437464];
    const nanhuBounds = L.latLngBounds(
      [41.7617, 123.4142],
      [41.7699, 123.4239]
    );

    const map = L.map("map", {
      zoomControl: true,
      minZoom: 15,
      maxZoom: 19,
      maxBounds: nanhuBounds,
      maxBoundsViscosity: 1.0,
    }).setView(nanhuCenter, 15);

    map.fitBounds(nanhuBounds, {
      padding: [6, 6],
    });

    // 多底图兜底：高德主源 -> 高德备源 -> OSM
    const tileProviders = [
      {
        name: "高德主源",
        url: "https://webrd0{s}.is.autonavi.com/appmaptile?lang=zh_cn&size=1&scale=1&style=8&x={x}&y={y}&z={z}",
        options: {
          subdomains: [1, 2, 3, 4],
          attribution: "&copy; 高德地图",
          maxZoom: 19,
        },
      },
      {
        name: "高德备源",
        url: "https://webst0{s}.is.autonavi.com/appmaptile?style=6&x={x}&y={y}&z={z}",
        options: {
          subdomains: [1, 2, 3, 4],
          attribution: "&copy; 高德地图",
          maxZoom: 19,
        },
      },
      {
        name: "OSM 兜底",
        url: "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",
        options: {
          attribution: "&copy; OpenStreetMap",
          maxZoom: 19,
        },
      },
    ];

    let activeLayer = null;
    let providerIndex = -1;
    const tileErrorLimit = 6;

    function showMapNotice(text) {
      const old = document.getElementById("mapNotice");
      if (old) {
        old.remove();
      }
      const notice = document.createElement("p");
      notice.id = "mapNotice";
      notice.className = "subtitle";
      notice.textContent = text;
      const mapPanel = document.querySelector("section.panel");
      mapPanel.insertBefore(notice, document.getElementById("map"));
    }

    function mountTileLayer(nextIndex) {
      if (nextIndex >= tileProviders.length) {
        showMapNotice("地图底图加载失败，请稍后刷新重试。\n若持续失败，可检查网络或切换科学网络环境。");
        return;
      }

      providerIndex = nextIndex;
      const provider = tileProviders[providerIndex];
      let errorCount = 0;

      if (activeLayer) {
        map.removeLayer(activeLayer);
      }

      activeLayer = L.tileLayer(provider.url, provider.options).addTo(map);
      showMapNotice(`当前底图：${provider.name}`);

      activeLayer.on("tileerror", () => {
        errorCount += 1;
        if (errorCount >= tileErrorLimit) {
          mountTileLayer(providerIndex + 1);
        }
      });
    }

    mountTileLayer(0);

    const glowingIcon = L.divIcon({
      className: "glow-marker",
      html: '<span></span>',
      iconSize: [18, 18],
      iconAnchor: [9, 9],
    });

    places.forEach((place) => {
      const marker = L.marker([place.lat, place.lng], { icon: glowingIcon }).addTo(map);
      marker.bindPopup(`
        <div class="popup-card">
          <h3>${place.name}</h3>
          <p>${place.summary}</p>
          <a href="/place/${place.id}">查看详情</a>
        </div>
      `);
    });
  </script>

  <script>
    (function() {
      var canvas = document.getElementById("particles-canvas");
      if (!canvas) return;
      var ctx = canvas.getContext("2d");
      var w, h, mouseX = -999, mouseY = -999;
      var particles = [];
      var maxP = 80;
      var connectDist = 150;

      function resize() {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
      }
      resize();
      window.addEventListener("resize", resize);

      document.addEventListener("mousemove", function(e) {
        mouseX = e.clientX;
        mouseY = e.clientY;
      });
      document.addEventListener("mouseleave", function() {
        mouseX = -999;
        mouseY = -999;
      });

      for (var i = 0; i < maxP; i++) {
        var p = {
          x: Math.random() * w,
          y: Math.random() * h,
          r: Math.random() * 2.2 + 0.6,
          vx: (Math.random() - 0.5) * 0.35,
          vy: (Math.random() - 0.5) * 0.35,
          o: Math.random() * 0.6 + 0.25
        };
        p.baseO = p.o;
        particles.push(p);
      }

      function draw() {
        ctx.clearRect(0, 0, w, h);

        for (var i = 0; i < particles.length; i++) {
          var p = particles[i];
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < 0) p.x = w;
          if (p.x > w) p.x = 0;
          if (p.y < 0) p.y = h;
          if (p.y > h) p.y = 0;

          // 鼠标排斥
          var dx = p.x - mouseX;
          var dy = p.y - mouseY;
          var dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 120 && dist > 0) {
            p.x += (dx / dist) * 1.2;
            p.y += (dy / dist) * 1.2;
            p.o = Math.min(1, p.baseO + 0.4);
          } else {
            p.o += (p.baseO - p.o) * 0.05;
          }

          // 星座连线
          for (var j = i + 1; j < particles.length; j++) {
            var q = particles[j];
            var cdx = p.x - q.x;
            var cdy = p.y - q.y;
            var cdist = Math.sqrt(cdx * cdx + cdy * cdy);
            if (cdist < connectDist) {
              ctx.beginPath();
              ctx.moveTo(p.x, p.y);
              ctx.lineTo(q.x, q.y);
              ctx.strokeStyle = "rgba(124,194,255," + (0.08 * (1 - cdist / connectDist)) + ")";
              ctx.lineWidth = 0.5;
              ctx.stroke();
            }
          }
        }

        for (var k = 0; k < particles.length; k++) {
          var pk = particles[k];
          ctx.beginPath();
          ctx.arc(pk.x, pk.y, pk.r, 0, Math.PI * 2);
          ctx.fillStyle = "rgba(124,194,255," + pk.o + ")";
          ctx.fill();
          ctx.beginPath();
          ctx.arc(pk.x, pk.y, pk.r * 3, 0, Math.PI * 2);
          ctx.fillStyle = "rgba(157,78,221," + (pk.o * 0.08) + ")";
          ctx.fill();
        }

        requestAnimationFrame(draw);
      }
      draw();
    })();
  </script>

  <footer class="site-footer">
    <p>&copy; 2026 东北大学校史地图 &middot; 记录历史，传承精神</p>
    <p>联系QQ：228343975</p>
  </footer>

  <% if (user && user.isAdmin) { %>
  <div class="visit-badge">
    <span class="visit-icon">👁</span>
    <span>累计访问</span>
    <span class="visit-count"><%= typeof visitCount !== 'undefined' ? visitCount : 0 %></span>
  </div>
  <% } %>
</body>
</html>