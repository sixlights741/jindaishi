<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>东北大学校史地图</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <canvas id="particles-canvas"></canvas>
  <header class="topbar topbar-main">
    <div class="brand-block">
      <img src="/images/neusign.jpg" alt="东北大学校徽" class="brand-emblem" />
      <div>
      <h1>NEU数字地图</h1>
      <p>欢迎你，<%= user.studentId %></p>
      </div>
    </div>
    <div class="actions">
      <% if (user.isAdmin) { %>
        <a href="/admin" class="btn">管理员后台</a>
      <% } %>
  <a href="/profile/password" class="btn ghost">改密码</a>
      <form method="post" action="/logout">
        <button type="submit" class="btn">退出登录</button>
      </form>
    </div>
  </header>

  <section class="hero-stats">
    <div class="stat-item">
      <span class="stat-number"><%= places.length %></span>
      <span class="stat-label">历史地点</span>
    </div>
    <div class="stat-item">
      <span class="stat-number">东北大学</span>
      <span class="stat-label">NEU</span>
    </div>
  </section>

  <main class="container">
    <section class="panel">
      <h2>地图导航</h2>
      <p>点击地图上的发光点，进入地点详情页。</p>
      <div id="map">
        <div class="map-img-wrap">
          <img src="/images/map_pic.jpg" alt="校园地图" class="map-base-img" />
          <div class="map-markers" id="mapMarkers"></div>
        </div>
      </div>
    </section>

    <aside class="panel list-panel">
      <h2>地点列表</h2>
      <div class="card-stack-wrapper" id="cardStackWrapper">
        <!-- 堆叠预览层（点击弹出浮层） -->
        <div class="stack-preview" id="stackPreview">
          <div class="preview-card preview-card-3"></div>
          <div class="preview-card preview-card-2"></div>
          <div class="preview-card preview-card-1">
            <div class="preview-inner">
              <span class="preview-icon">📜</span>
              <span class="preview-text">点击展开地点</span>
              <span class="preview-arrow">▼</span>
            </div>
          </div>
        </div>
      </div>
    </aside>
  </main>

  <!-- ===== 全屏地点浮层 ===== -->
  <div class="places-overlay" id="placesOverlay">
    <div class="places-backdrop" id="placesBackdrop"></div>
    <div class="places-sheet" id="placesSheet">
      <div class="places-header">
        <h2>📍 探索历史地点</h2>
        <button class="places-close" id="placesClose" aria-label="关闭">✕</button>
      </div>
      <div class="places-grid" id="placesGrid">
        <% places.forEach((place, idx) => { %>
          <a href="/place/<%= place.id %>" class="pop-card" style="--i: <%= idx %>;" data-index="<%= idx %>">
            <strong><%= place.name %></strong>
            <span><%= place.summary %></span>
          </a>
        <% }) %>
      </div>
    </div>
  </div>

  <script id="places-data" type="application/json"><%- JSON.stringify(places) %></script>
  <script>
    (function() {
      const placesDataEl = document.getElementById("places-data");
      const places = JSON.parse(placesDataEl?.textContent || "[]");
      const markersEl = document.getElementById("mapMarkers");
      const mapImg = document.querySelector(".map-base-img");
      if (!markersEl || !mapImg) return;

      // map_pic.jpg 实际像素尺寸
      const IMG_W = 4096, IMG_H = 2988;

      // 创建所有标记点 DOM（先隐藏）
      const markerEls = [];
      places.forEach((place) => {
        if (place.px == null || place.py == null) return;
        const marker = document.createElement("a");
        marker.href = "/place/" + place.id;
        marker.className = "map-marker";
        marker.title = place.name;
        marker.style.visibility = "hidden";
        marker.innerHTML = '<span class="map-marker-dot"></span><span class="map-marker-label">' + place.name + '</span>';
        markersEl.appendChild(marker);
        markerEls.push({ el: marker, px: place.px, py: place.py });
      });

      // 根据图片实际显示区域重新定位标记点
      function repositionMarkers() {
        if (markerEls.length === 0) return;
        var containerRect = markersEl.getBoundingClientRect();
        if (containerRect.width === 0 || containerRect.height === 0) return;
        var imgRect = mapImg.getBoundingClientRect();
        if (imgRect.width === 0 || imgRect.height === 0) return;

        // 图片在容器内的偏移（object-fit: contain 可能导致留白）
        var offsetX = imgRect.left - containerRect.left;
        var offsetY = imgRect.top - containerRect.top;
        var imgW = imgRect.width;
        var imgH = imgRect.height;

        markerEls.forEach(function(item) {
          // 坐标在图片实际显示区域中的像素位置
          // 注意：Leaflet CRS.Simple 的 lat（即 py）从底部向上增长，
          // 但 CSS top 从顶部向下增长，所以 Y 轴需要翻转
          var xInImg = (item.px / IMG_W) * imgW;
          var yInImg = ((IMG_H - item.py) / IMG_H) * imgH;
          // 转换为容器内的像素位置
          var x = offsetX + xInImg;
          var y = offsetY + yInImg;
          // 转换为容器百分比
          item.el.style.left = (x / containerRect.width * 100).toFixed(2) + "%";
          item.el.style.top  = (y / containerRect.height * 100).toFixed(2) + "%";
          item.el.style.visibility = "visible";
        });
      }

      // 图片加载完成后定位，窗口大小变化时重新定位
      if (mapImg.complete) {
        repositionMarkers();
      } else {
        mapImg.addEventListener("load", repositionMarkers, { once: true });
      }
      window.addEventListener("resize", repositionMarkers);
    })();
  </script>

  <script>
    // ===== 全屏浮层：点击堆叠预览 → 弹出地点选择 =====
    (function() {
      var preview = document.getElementById("stackPreview");
      var overlay = document.getElementById("placesOverlay");
      var backdrop = document.getElementById("placesBackdrop");
      var closeBtn = document.getElementById("placesClose");
      var sheet = document.getElementById("placesSheet");
      var cards = document.querySelectorAll("#placesGrid .pop-card");

      if (!preview || !overlay) return;

      function openOverlay() {
        overlay.classList.add("active");
        document.body.style.overflow = "hidden";
        // 卡片依次弹出
        cards.forEach(function(card, i) {
          card.style.animationDelay = (i * 0.05) + "s";
          card.classList.add("popping");
        });
      }

      function closeOverlay() {
        overlay.classList.remove("active");
        document.body.style.overflow = "";
        cards.forEach(function(card) {
          card.classList.remove("popping");
          card.style.animationDelay = "0s";
        });
      }

      preview.addEventListener("click", function(e) {
        e.preventDefault();
        openOverlay();
      });

      closeBtn.addEventListener("click", closeOverlay);
      backdrop.addEventListener("click", closeOverlay);

      document.addEventListener("keydown", function(e) {
        if (e.key === "Escape" && overlay.classList.contains("active")) {
          closeOverlay();
        }
      });
    })();
  </script>

  <script>
    (function() {
      var canvas = document.getElementById("particles-canvas");
      if (!canvas) return;
      var ctx = canvas.getContext("2d");
      var w, h, mouseX = -999, mouseY = -999;
      var particles = [];
      var maxP = 80;
      var connectDist = 150;

      function resize() {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
      }
      resize();
      window.addEventListener("resize", resize);

      document.addEventListener("mousemove", function(e) {
        mouseX = e.clientX;
        mouseY = e.clientY;
      });
      document.addEventListener("mouseleave", function() {
        mouseX = -999;
        mouseY = -999;
      });

      for (var i = 0; i < maxP; i++) {
        var p = {
          x: Math.random() * w,
          y: Math.random() * h,
          r: Math.random() * 2.2 + 0.6,
          vx: (Math.random() - 0.5) * 0.35,
          vy: (Math.random() - 0.5) * 0.35,
          o: Math.random() * 0.6 + 0.25
        };
        p.baseO = p.o;
        particles.push(p);
      }

      function draw() {
        ctx.clearRect(0, 0, w, h);

        for (var i = 0; i < particles.length; i++) {
          var p = particles[i];
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < 0) p.x = w;
          if (p.x > w) p.x = 0;
          if (p.y < 0) p.y = h;
          if (p.y > h) p.y = 0;

          // 鼠标排斥
          var dx = p.x - mouseX;
          var dy = p.y - mouseY;
          var dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 120 && dist > 0) {
            p.x += (dx / dist) * 1.2;
            p.y += (dy / dist) * 1.2;
            p.o = Math.min(1, p.baseO + 0.4);
          } else {
            p.o += (p.baseO - p.o) * 0.05;
          }

          // 星座连线
          for (var j = i + 1; j < particles.length; j++) {
            var q = particles[j];
            var cdx = p.x - q.x;
            var cdy = p.y - q.y;
            var cdist = Math.sqrt(cdx * cdx + cdy * cdy);
            if (cdist < connectDist) {
              ctx.beginPath();
              ctx.moveTo(p.x, p.y);
              ctx.lineTo(q.x, q.y);
              ctx.strokeStyle = "rgba(124,194,255," + (0.08 * (1 - cdist / connectDist)) + ")";
              ctx.lineWidth = 0.5;
              ctx.stroke();
            }
          }
        }

        for (var k = 0; k < particles.length; k++) {
          var pk = particles[k];
          ctx.beginPath();
          ctx.arc(pk.x, pk.y, pk.r, 0, Math.PI * 2);
          ctx.fillStyle = "rgba(124,194,255," + pk.o + ")";
          ctx.fill();
          ctx.beginPath();
          ctx.arc(pk.x, pk.y, pk.r * 3, 0, Math.PI * 2);
          ctx.fillStyle = "rgba(157,78,221," + (pk.o * 0.08) + ")";
          ctx.fill();
        }

        requestAnimationFrame(draw);
      }
      draw();
    })();
  </script>

  <footer class="site-footer">
    <p>&copy; 2026 东北大学校史地图 &middot; 记录历史，传承精神</p>
    <p>联系QQ：228343975</p>
  </footer>

  <% if (user && user.isAdmin) { %>
  <div class="visit-badge">
    <span class="visit-icon">👁</span>
    <span>累计访问</span>
    <span class="visit-count"><%= typeof visitCount !== 'undefined' ? visitCount : 0 %></span>
  </div>
  <% } %>
</body>
</html>