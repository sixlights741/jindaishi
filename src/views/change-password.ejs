<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>修改密码 - 东北大学校史地图</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="auth-body">
  <main class="auth-card">
    <h1>修改密码</h1>
    <p class="subtitle">当前账号：<%= user.studentId %></p>

    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>
    <% if (success) { %>
      <p class="success"><%= success %></p>
    <% } %>

    <form method="post" action="/profile/password" class="form">
      <label>当前密码</label>
      <input type="password" name="currentPassword" required />

      <label>新密码（至少6位）</label>
      <input type="password" name="newPassword" minlength="6" required />

      <label>确认新密码</label>
      <input type="password" name="confirmPassword" minlength="6" required />

      <button type="submit">保存新密码</button>
      <a href="/" class="back-link">返回地图</a>
    </form>
  </main>
</body>
<% if (autoRedirectToLogin && success) { %>
  <script>
    alert("改动成功");
    setTimeout(() => {
      window.location.href = "/login";
    }, 800);
  </script>
<% } %>
</html>