<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= place.name %> - 东北大学校史地图</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="topbar">
    <div class="brand-block">
      <img src="/images/neusign.jpg" alt="东北大学校徽" class="brand-emblem" />
      <div>
      <h1><%= place.name %></h1>
      <p>校史地点详情</p>
      </div>
    </div>
    <div class="actions">
      <a href="/" class="btn ghost">返回地图</a>
      <form method="post" action="/logout">
        <button type="submit" class="btn">退出登录</button>
      </form>
    </div>
  </header>

  <main class="detail-container">
    <article class="detail-card">
      <img src="<%= place.image %>" alt="<%= place.name %>" class="detail-image" />
      <p class="tag"><%= place.period %></p>
      <p class="lead"><%= place.summary %></p>
      <div class="content"><%= place.content %></div>

      <%
        const rawVideoUrl = (place.videoUrl || "").trim();
        let embedUrl = "";
        if (rawVideoUrl) {
          if (rawVideoUrl.includes("player.bilibili.com")) {
            embedUrl = rawVideoUrl;
          } else {
            const bvidMatch = rawVideoUrl.match(/BV[0-9A-Za-z]+/);
            const aidMatch = rawVideoUrl.match(/av(\d+)/i);
            if (bvidMatch) {
              embedUrl = `https://player.bilibili.com/player.html?bvid=${bvidMatch[0]}&high_quality=1&autoplay=0`;
            } else if (aidMatch) {
              embedUrl = `https://player.bilibili.com/player.html?aid=${aidMatch[1]}&high_quality=1&autoplay=0`;
            }
          }
        }
      %>

      <% if (embedUrl) { %>
        <section class="video-section">
          <h3 class="gallery-title">地点视频</h3>
          <div class="video-embed">
            <iframe
              src="<%= embedUrl %>"
              allowfullscreen
              webkitallowfullscreen
              mozallowfullscreen
              allow="autoplay; fullscreen; picture-in-picture; encrypted-media"
            ></iframe>
          </div>
        </section>
      <% } %>

      <section class="assistant-panel" data-place-id="<%= place.id %>" data-user-id="<%= user.studentId %>">
        <h3 class="gallery-title">AI 讲解助手</h3>
        <div class="assistant-suggestions" id="assistantSuggestions">
          <% if (Array.isArray(place.qaRules) && place.qaRules.length > 0) { %>
            <% place.qaRules.forEach((rule) => { %>
              <button type="button" class="suggestion-chip" data-question="<%= rule.question %>" data-answer="<%= rule.answer %>"><%= rule.question %></button>
            <% }) %>
          <% } %>
        </div>
        <button type="button" id="assistantClearBtn" class="btn ghost">清空对话记录</button>
        <div id="assistantMessages" class="assistant-messages">
          <article class="assistant-bubble assistant-bubble-bot">
            你好，我是讲解小助手 👋 请输入你想了解的问题。
          </article>
        </div>
        <form id="assistantForm" class="assistant-form">
          <input id="assistantQuestion" type="text" maxlength="300" placeholder="例如：请用三句话介绍这个地点" required />
          <button type="submit">提问</button>
        </form>
      </section>

      <% if (Array.isArray(place.drawings) && place.drawings.length > 0) { %>
        <h3 class="gallery-title">小组手绘图展示</h3>
        <section class="drawing-grid">
          <% place.drawings.forEach((drawing) => { %>
            <article class="drawing-item">
              <img src="<%= drawing.url %>" alt="<%= drawing.caption || (place.name + '手绘图') %>" />
              <p><%= drawing.caption || '手绘图' %></p>
            </article>
          <% }) %>
        </section>
      <% } %>
    </article>
  </main>
  <script>
    (function () {
      const panel = document.querySelector(".assistant-panel");
      if (!panel) {
        return;
      }

      const placeId = panel.dataset.placeId;
      const userId = panel.dataset.userId || "unknown";
      const form = document.getElementById("assistantForm");
      const questionInput = document.getElementById("assistantQuestion");
      const messages = document.getElementById("assistantMessages");
      const suggestions = document.getElementById("assistantSuggestions");
      const clearBtn = document.getElementById("assistantClearBtn");
      const submitButton = form.querySelector("button[type='submit']");
      const storageKey = `assistant-chat-${userId}-${placeId}`;
      const initialMessageHtml = `<article class="assistant-bubble assistant-bubble-bot">你好，我是讲解小助手 👋 请输入你想了解的问题。</article>`;

      function resetConversation() {
        messages.innerHTML = initialMessageHtml;
        messages.scrollTop = messages.scrollHeight;
        saveHistory();
      }

      function saveHistory() {
        sessionStorage.setItem(storageKey, messages.innerHTML);
      }

      function restoreHistory() {
        const saved = sessionStorage.getItem(storageKey);
        if (!saved) {
          resetConversation();
          return;
        }
        messages.innerHTML = saved;
        messages.scrollTop = messages.scrollHeight;
      }

      function appendBubble(text, role) {
        const article = document.createElement("article");
        article.className = `assistant-bubble ${role === "user" ? "assistant-bubble-user" : "assistant-bubble-bot"}`;
        article.textContent = text;
        messages.appendChild(article);
        messages.scrollTop = messages.scrollHeight;
        saveHistory();
      }

      async function askQuestion(question) {
        if (!question) {
          return;
        }

        appendBubble(question, "user");
        questionInput.value = "";
        submitButton.disabled = true;
        submitButton.textContent = "思考中...";

        try {
          const response = await fetch("/api/assistant", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ placeId, question }),
          });

          const contentType = response.headers.get("content-type") || "";
          const isJson = contentType.includes("application/json");
          const payload = isJson ? await response.json() : null;

          if (response.status === 401) {
            appendBubble("登录已失效，请重新登录后再继续提问。", "bot");
            return;
          }

          if (response.status === 404) {
            appendBubble("小助手接口不存在（404），请重启服务后刷新页面再试。", "bot");
            return;
          }

          if (!response.ok) {
            const message = payload && payload.error ? payload.error : `请求失败（${response.status}）`;
            appendBubble(message, "bot");
            return;
          }

          if (!payload || !payload.answer) {
            appendBubble("服务返回格式异常，请稍后重试。", "bot");
            return;
          }

          const sourceLabelMap = {
            cloud: payload.providerLabel || payload.model || "云端模型",
            preset: "预设问答",
            local: "本地规则",
            "fallback-fixed": "固定兜底",
          };
          const sourceLabel = sourceLabelMap[payload.source] || "本地规则";
          const fallbackTip = payload.source !== "cloud" && payload.fallbackReason
            ? `\n（云端降级原因：${payload.fallbackReason}）`
            : "";
          appendBubble(`${payload.answer}\n\n（回答来源：${sourceLabel}）${fallbackTip}`, "bot");
        } catch (error) {
          appendBubble("网络请求失败，请稍后重试。", "bot");
        } finally {
          submitButton.disabled = false;
          submitButton.textContent = "提问";
          questionInput.focus();
        }
      }

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const question = (questionInput.value || "").trim();
        await askQuestion(question);
      });

      suggestions.addEventListener("click", async (event) => {
        const target = event.target.closest(".suggestion-chip");
        if (!target) {
          return;
        }
        const question = (target.dataset.question || "").trim();
        const presetAnswer = (target.dataset.answer || "").trim();
        if (!question || !presetAnswer) {
          return;
        }
        appendBubble(question, "user");
        appendBubble(`${presetAnswer}\n\n（回答来源：预设问答）`, "bot");
      });

      clearBtn.addEventListener("click", () => {
        resetConversation();
        questionInput.focus();
      });

      restoreHistory();
    })();
  </script>

  <footer class="site-footer">
    <p>&copy; 2026 东北大学校史地图 &middot; <a href="/">返回首页</a></p>
    <p>联系QQ：228343975</p>
  </footer>

  <div class="visit-badge">
    <span class="visit-icon">👁</span>
    <span>累计访问</span>
    <span class="visit-count"><%= typeof visitCount !== 'undefined' ? visitCount : 0 %></span>
  </div>
</body>
</html>