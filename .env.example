# =============================
# 东北大学校史地图 - 环境变量模板
# 复制本文件并按你的部署方式设置环境变量
# 注意：本项目当前不自动读取 .env 文件，
# 请在终端/服务器面板/PM2 中注入这些变量。
# =============================

# 服务端口（可选）
PORT=3000

# Session 密钥（建议改成随机长字符串）
SESSION_SECRET=replace-with-a-long-random-secret

# AI Key（二选一，推荐填 OPENAI_API_KEY）
OPENAI_API_KEY=
# AI_API_KEY=

# AI 模型名（可选）
AI_MODEL=gpt-4o-mini

# OpenAI 兼容网关地址（可选）
OPENAI_BASE_URL=https://api.openai.com/v1

# 自定义完整接口地址（可选，优先级更高）
# AI_API_URL=https://your-provider.example.com/v1/chat/completions
